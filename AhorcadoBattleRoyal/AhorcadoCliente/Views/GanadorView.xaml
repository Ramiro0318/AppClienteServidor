<UserControl x:Class="AhorcadoCliente.Views.GanadorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">
            <Border Width="120" Height="120" 
                    CornerRadius="60" 
                    Background="#F1C40F" 
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center">
                <TextBlock Text="🏆" 
                          FontSize="60" 
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="¡FELICIDADES!" 
                      FontSize="28" 
                      FontWeight="Bold"
                      Foreground="#2C3E50"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>

            <TextBlock Text="ERES EL GANADOR" 
                      FontSize="20" 
                      FontWeight="SemiBold"
                      Foreground="#F39C12"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"/>

            <TextBlock Text="Todos los demás fueron eliminados" 
                      FontSize="14" 
                      Foreground="#7F8C8D"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"
                      TextWrapping="Wrap"/>

            <TextBlock Text="La partida ha terminado" 
                      FontSize="14" 
                      Foreground="#7F8C8D"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"
                      TextWrapping="Wrap"/>

            <Button Content="JUGAR DE NUEVO" 
                    Command="{Binding DataContext.VolverAConexionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="50"
                    Background="#27AE60"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>