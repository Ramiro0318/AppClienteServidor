<UserControl x:Class="AhorcadoCliente.Views.SalaEsperaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="SALA DE ESPERA" 
                      FontSize="24" 
                      FontWeight="Light"
                      Foreground="#2C3E50"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,20"/>

            <Border Background="#FADBD8" 
                    CornerRadius="10" 
                    Padding="15"
                    Margin="0,0,0,20"
                    BorderBrush="#E74C3C"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="⚰️ JUGADOR ELIMINADO" 
                              Foreground="#C0392B"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="Ana" 
                              FontSize="22" 
                              FontWeight="Bold"
                              Foreground="#C0392B"
                              HorizontalAlignment="Center"/>
                    </StackPanel>
            </Border>

            <TextBlock Text="JUGADORES EN SALA" 
                      FontSize="12" 
                      Foreground="#7F8C8D"
                      Margin="0,0,0,10"/>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Height="200">
                <ItemsControl>
                    <Border Background="#F8F9F9" CornerRadius="5" Padding="12" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•" Foreground="#27AE60" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="Carlos" FontSize="14"/>
                        </Grid>
                    </Border>
                    <Border Background="#F8F9F9" CornerRadius="5" Padding="12" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•" Foreground="#27AE60" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="Ana" FontSize="14"/>
                        </Grid>
                    </Border>
                    <Border Background="#F8F9F9" CornerRadius="5" Padding="12" Margin="0,0,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="•" Foreground="#27AE60" FontSize="20" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="Luis (tú)" FontSize="14" FontWeight="Bold"/>
                        </Grid>
                    </Border>
                </ItemsControl>
            </ScrollViewer>

            <Border Background="#F0F3F4" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="⏳" FontSize="24" HorizontalAlignment="Center"/>
                    <TextBlock Text="Esperando que el anfitrión inicie..." 
                              Foreground="#566573"
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Button Content="INICIAR PARTIDA (SERVIDOR)" 
                    Command="{Binding DataContext.IrAJuegoCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="45"
                    Background="#3498DB"
                    Foreground="White"
                    FontSize="14"
                    FontWeight="Bold"
                    Margin="0,20,0,0"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>