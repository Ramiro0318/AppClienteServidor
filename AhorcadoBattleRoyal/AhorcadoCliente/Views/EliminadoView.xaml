<UserControl x:Class="AhorcadoCliente.Views.EliminadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">
            <Border Width="120" Height="120" 
                    CornerRadius="60" 
                    Background="#E74C3C" 
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center">
                <TextBlock Text="💀" 
                          FontSize="60" 
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="EXPULSADO" 
                      FontSize="28" 
                      FontWeight="Bold"
                      Foreground="#C0392B"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"/>

            <TextBlock Text="Has sido eliminado de la partida" 
                      FontSize="16" 
                      Foreground="#7F8C8D"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"
                      TextWrapping="Wrap"/>

            <Border Background="#F8F9F9" 
                    CornerRadius="8" 
                    Padding="15"
                    Margin="0,0,0,30">
                <TextBlock Text="La palabra era: CASA BLANCA" 
                          FontSize="16" 
                          FontWeight="Bold"
                          Foreground="#2C3E50"
                          HorizontalAlignment="Center"/>
            </Border>

            <Button Content="VOLVER A JUGAR" 
                    Command="{Binding DataContext.VolverAConexionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="50"
                    Background="#27AE60"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"/>
        </StackPanel>
    </Grid>
</UserControl>