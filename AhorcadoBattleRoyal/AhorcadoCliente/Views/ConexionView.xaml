<UserControl x:Class="AhorcadoCliente.Views.ConexionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="30">
            <Border Width="120" Height="120" 
                    CornerRadius="60" 
                    Background="#3498DB" 
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center">
                <TextBlock Text="🎮" 
                          FontSize="60" 
                          Foreground="White"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </Border>

            <TextBlock Text="CONÉCTATE A LA PARTIDA" 
                      FontSize="14" 
                      Foreground="#7F8C8D"
                      HorizontalAlignment="Center"
                      Margin="0,0,0,30"/>

            <TextBlock Text="DIRECCIÓN IP" 
                      FontSize="12" 
                      Foreground="#34495E"
                      Margin="0,0,0,5"/>
            <Border BorderBrush="#BDC3C7" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Margin="0,0,0,20">
                <TextBox Text="127.0.0.1" 
                         Padding="10"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"/>
            </Border>

            <TextBlock Text="TU NOMBRE" 
                      FontSize="12" 
                      Foreground="#34495E"
                      Margin="0,0,0,5"/>
            <Border BorderBrush="#BDC3C7" 
                    BorderThickness="1" 
                    CornerRadius="5" 
                    Margin="0,0,0,20">
                <TextBox Text="Jugador" 
                         Padding="10"
                         BorderThickness="0"
                         Background="Transparent"
                         FontSize="14"/>
            </Border>

            <Button Content="CONECTAR" 
                    Command="{Binding DataContext.IrASalaCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="50"
                    Background="#27AE60"
                    Foreground="White"
                    FontSize="16"
                    FontWeight="Bold"
                    Cursor="Hand"/>

            <TextBlock Text="Mensaje de error" 
                       Foreground="#E74C3C"
                       TextWrapping="Wrap"
                       Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>