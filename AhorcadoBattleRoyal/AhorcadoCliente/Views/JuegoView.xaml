<UserControl x:Class="AhorcadoCliente.Views.JuegoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="#2C3E50" 
                    CornerRadius="25" 
                    Padding="15"
                    Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="🎯 " FontSize="18" Foreground="#F1C40F"/>
                    <TextBlock Text="TURNO DE: " Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                    <TextBlock Text="Carlos" Foreground="#F1C40F" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" 
                    Background="#F8F9F9" 
                    CornerRadius="10" 
                    Padding="20"
                    Margin="0,0,0,20">
                <StackPanel>
                    <Border Width="150" Height="150" 
                            Background="#E8E8E8" 
                            CornerRadius="75"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,15">
                        <TextBlock Text="🪢" FontSize="80" Foreground="#7F8C8D"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="_ _ _ _   _ _ _ _ _" 
                              FontSize="28" FontWeight="Bold"
                              Foreground="#2C3E50" 
                              HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" 
                    Background="#FEF9E7" 
                    CornerRadius="8" 
                    Padding="10"
                    Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="❤️ " FontSize="20"/>
                    <TextBlock Text="3" FontSize="20" FontWeight="Bold" Foreground="#C0392B"/>
                    <TextBlock Text=" / 6" FontSize="16" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="3" Margin="0,0,0,20">
                <TextBlock Text="SELECCIONA UNA LETRA" 
                          FontSize="12" Foreground="#7F8C8D"
                          Margin="0,0,0,10"/>

                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="A" Width="45" Height="45" Margin="3"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Content="B" Width="45" Height="45" Margin="3"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Content="C" Width="45" Height="45" Margin="3"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Content="D" Width="45" Height="45" Margin="3"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                    <Button Content="E" Width="45" Height="45" Margin="3"
                            Background="#3498DB" Foreground="White" FontWeight="Bold" BorderThickness="0"/>
                </WrapPanel>
            </StackPanel>

            <Border Grid.Row="4" 
                    Background="#E8F8F5" 
                    CornerRadius="10" 
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="JUGADORES EN JUEGO" 
                              FontSize="12" Foreground="#1ABC9C"
                              Margin="0,0,0,10"/>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Carlos" Foreground="#148F77"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Ana" Foreground="#148F77"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="✓" Foreground="#27AE60" FontWeight="Bold" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Luis (tú)" Foreground="#148F77" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <Button Grid.Row="5" 
                    Content="VOLVER A SALA"
                    Command="{Binding DataContext.VolverAConexionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Height="40"
                    Background="#95A5A6"
                    Foreground="White"
                    Margin="0,20,0,0"
                    Cursor="Hand"/>
        </Grid>
    </ScrollViewer>
</UserControl>