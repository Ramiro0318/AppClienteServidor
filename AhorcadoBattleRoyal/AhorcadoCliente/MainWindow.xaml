<Window x:Class="AhorcadoCliente.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AhorcadoCliente.Views"
        xmlns:viewModels="clr-namespace:AhorcadoCliente.ViewModels"
        Title="AHORCADO BATTLE ROYALE"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="ElegantButton" TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🎮 AHORCADO BATTLE ROYALE" 
                   FontSize="18" 
                   FontWeight="Bold" 
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.Resources>
                <local:ConexionView x:Key="VistaConexion"/>
                <local:SalaEsperaView x:Key="VistaSala"/>
                <local:JuegoView x:Key="VistaJuego"/>
            </Grid.Resources>

            <ContentControl>
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VistaActual}" Value="{x:Static viewModels:TipoVista.Conexion}">
                                <Setter Property="Content" Value="{StaticResource VistaConexion}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VistaActual}" Value="{x:Static viewModels:TipoVista.SalaEspera}">
                                <Setter Property="Content" Value="{StaticResource VistaSala}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding VistaActual}" Value="{x:Static viewModels:TipoVista.Juego}">
                                <Setter Property="Content" Value="{StaticResource VistaJuego}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Grid>

        <TextBlock Grid.Row="2" 
                   Text="TCP 7777" 
                   Foreground="#95A5A6"
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0"/>
    </Grid>
</Window>