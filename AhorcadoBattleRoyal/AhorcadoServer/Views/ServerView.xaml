<UserControl x:Class="AhorcadoServer.Views.ServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AhorcadoServer.Views"
             xmlns:viewModels="clr-namespace:AhorcadoServer.ViewModels">

    <UserControl.DataContext>
        <viewModels:MainViewModel/>
    </UserControl.DataContext>

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ServerButton" TargetType="Button">
            <Setter Property="Background" Value="#2C3E50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#95A5A6"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="CONTROL DEL SERVIDOR" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <Button Content="ABRIR SALA" Style="{StaticResource ServerButton}" Background="#E67E22" Command="{Binding AbrirSalaCommand}" IsEnabled="{Binding SalaCerrada}"/>
                        <Button Content="NUEVA RONDA" Style="{StaticResource ServerButton}" Background="#3498DB" Command="{Binding MostrarModalNuevaRondaCommand}"/>
                    </WrapPanel>
                    <TextBlock Text="Puerto: 7777" Foreground="#95A5A6" FontSize="11" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="JUGADORES CONECTADOS" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                    <ScrollViewer Height="120" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Clientes}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="•" Foreground="#27AE60" FontSize="16" Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Nombre}" FontSize="13"/>
                                    </Grid>
                                    
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="LOG DE EVENTOS" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,10"/>
                    <ScrollViewer Height="200" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Logs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="{Binding .}" FontFamily="Consolas" FontSize="12" Foreground="#2C3E50" Margin="0,2"/>
                                    </Grid>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="#2C3E50" CornerRadius="8" Padding="15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="ESTADO ACTUAL" FontSize="11" Foreground="#95A5A6" Margin="0,0,0,5"/>
                        <TextBlock Text="Juego en curso - Ronda 1" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Border Background="#FEF9E7" CornerRadius="5" Padding="10" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="ERRORES" FontSize="9" Foreground="#C0392B" HorizontalAlignment="Center"/>
                                <TextBlock Text="3" Foreground="#C0392B" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Background="#E8F8F5" CornerRadius="5" Padding="10" Margin="5,0">
                            <StackPanel>
                                <TextBlock Text="TURNO" FontSize="9" Foreground="#148F77" HorizontalAlignment="Center"/>
                                <TextBlock Text="Carlos" Foreground="#148F77" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="0" Grid.RowSpan="2"
                Background="#80000000"
                Visibility="{Binding ModalNuevaRondaVisible, Converter={StaticResource BoolToVis}}">
            <Border Width="450" Height="250"
                    Background="White"
                    CornerRadius="10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel Margin="25">
                    <TextBlock Text="NUEVA RONDA" FontSize="20" FontWeight="Bold" Foreground="#2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                    <TextBlock Text="FRASE:" FontSize="12" Foreground="#7F8C8D" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="FrasePasswordBox" Height="40" FontSize="14" Padding="5" Margin="0,0,0,20"/>

                    <WrapPanel HorizontalAlignment="Center">
                        <Button Content="CANCELAR" Style="{StaticResource ServerButton}" Background="#95A5A6" Width="100" Margin="5" Command="{Binding CancelarNuevaRondaCommand}"/>
                        <Button Content="INICIAR" Style="{StaticResource ServerButton}" Background="#27AE60" Width="100" Margin="5" Command="{Binding IniciarNuevaRondaCommand}" CommandParameter="{Binding Text, ElementName=FrasePasswordBox}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>