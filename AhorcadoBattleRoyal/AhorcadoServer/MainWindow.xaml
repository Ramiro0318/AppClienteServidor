<Window x:Class="AhorcadoServer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AhorcadoServer.Views"
        xmlns:viewModels="clr-namespace:AhorcadoServer.ViewModels"
        Title="SERVIDOR AHORCADO BATTLE ROYALE" 
        Height="700" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResize"
        MinHeight="650" MinWidth="600">

    <Window.DataContext>
        <viewModels:MainViewModel/>
    </Window.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto"> 
        <local:ServerView Margin="20"/>
    </ScrollViewer>
</Window>